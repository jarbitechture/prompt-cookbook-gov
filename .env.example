# Prompt Cookbook — Environment Variables
# Copy this file to .env and fill in values
# In Azure App Service, set these in Configuration > Application Settings

# Required: API key for the LLM provider (OpenAI-compatible endpoint)
COOKBOOK_LLM_API_KEY=

# Optional: Base URL for Azure OpenAI or other OpenAI-compatible providers
# Azure OpenAI: https://{resource}.openai.azure.com/openai/deployments/{model}
# Ollama: http://localhost:11434/v1
# Leave blank for OpenAI direct
COOKBOOK_LLM_BASE_URL=

# Optional: Port (defaults to 3000)
PORT=3000

# Optional: Comma-separated SharePoint origins for iframe embedding
# SHAREPOINT_ORIGINS=https://yourtenant.sharepoint.com

# Optional: Set to "1" if behind a reverse proxy / load balancer
# TRUST_PROXY=1
