{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/chapters/*", "/api/*"]
  },
  "routes": [
    { "route": "/api/*", "allowedRoles": ["anonymous"] }
  ],
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-DNS-Prefetch-Control": "off",
    "Referrer-Policy": "no-referrer",
    "Content-Security-Policy": "frame-ancestors 'self' *.sharepoint.com *.office.com"
  },
  "responseOverrides": {
    "404": { "rewrite": "/index.html" }
  }
}
